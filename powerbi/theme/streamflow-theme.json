{
  "name": "StreamFlow Executive Premium",
  "description": "Premium executive theme for CEO Dashboard",
  "version": "2.0.0",
  "dataColors": [
    "#1B365D",
    "#0078D4",
    "#00BCF2",
    "#50E6FF",
    "#107C10",
    "#FFB900",
    "#E81123",
    "#767676",
    "#2D2D2D",
    "#008575",
    "#5C2D91",
    "#E3008C"
  ],
  "background": "#FFFFFF",
  "foreground": "#1A1A1A",
  "tableAccent": "#0078D4",
  "good": "#107C10",
  "neutral": "#FFB900",
  "bad": "#E81123",
  "maximum": "#1B365D",
  "center": "#0078D4",
  "minimum": "#50E6FF",
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ],
        "border": [
          {
            "color": {
              "solid": {
                "color": "#E5E5E5"
              }
            }
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#000000"
              }
            },
            "position": "Outer",
            "preset": "BottomRight",
            "transparency": 90
          }
        ],
        "visualHeader": [
          {
            "foreground": {
              "solid": {
                "color": "#003366"
              }
            }
          }
        ],
        "visualHeaderTooltip": [
          {
            "text": ""
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#F5F5F5"
              }
            },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#E5E5E5"
              }
            }
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#252423"
              }
            },
            "fontSize": 32,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#6C757D"
              }
            },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "header": [
          {
            "fontColor": {
              "solid": {
                "color": "#003366"
              }
            },
            "background": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "fontSize": 10
          }
        ],
        "items": [
          {
            "fontColor": {
              "solid": {
                "color": "#252423"
              }
            },
            "background": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "fontSize": 10
          }
        ]
      }
    },
    "lineChart": {
      "*": {
        "dataPoint": [
          {
            "lineStyle": "solid"
          }
        ]
      }
    },
    "table": {
      "*": {
        "columnHeaders": [
          {
            "fontColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "backColor": {
              "solid": {
                "color": "#003366"
              }
            },
            "fontSize": 10,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "values": [
          {
            "fontColor": {
              "solid": {
                "color": "#252423"
              }
            },
            "backColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "fontSize": 10
          }
        ],
        "total": [
          {
            "fontColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "backColor": {
              "solid": {
                "color": "#003366"
              }
            }
          }
        ],
        "grid": [
          {
            "gridVertical": true,
            "gridVerticalColor": {
              "solid": {
                "color": "#E5E5E5"
              }
            },
            "gridHorizontal": true,
            "gridHorizontalColor": {
              "solid": {
                "color": "#E5E5E5"
              }
            }
          }
        ]
      }
    },
    "textbox": {
      "*": {
        "general": [
          {
            "paragraphs": [
              {
                "textRuns": [
                  {
                    "value": "",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "12pt"
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  },
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 24,
      "color": "#003366"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 14,
      "color": "#252423"
    },
    "callout": {
      "fontFace": "Segoe UI",
      "fontSize": 32,
      "color": "#252423"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#6C757D"
    }
  }
}
